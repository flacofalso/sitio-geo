---
// Layout base: incluye TODO el schema JSON-LD y meta tags que los
// crawlers (Googlebot, GPTBot, ClaudeBot, PerplexityBot) leen en el
// HTML inicial. Astro renderiza esto como HTML estático: cero JS
// requerido para ver el contenido — requisito clave para bots de IA.
import { SITE } from '../config.js';

const {
  title,
  description = SITE.description,
  type = 'website',          // 'website' | 'article'
  publishedDate = null,      // ISO string para artículos
  modifiedDate = null,
  canonical = null,
} = Astro.props;

const pageUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).href;

// --- Schema base: Organization + WebSite (en todas las páginas) ---
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#organization`,
  name: SITE.organization.name,
  description: SITE.description,
  url: SITE.url,
  email: SITE.organization.email,
  areaServed: SITE.organization.areaServed,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.organization.addressLocality,
    addressRegion: SITE.organization.addressRegion,
    addressCountry: SITE.organization.addressCountry,
  },
  founder: { '@id': `${SITE.url}/#person` },
  sameAs: SITE.author.sameAs,
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: SITE.author.name,
  jobTitle: SITE.author.jobTitle,
  description: SITE.author.description,
  url: `${SITE.url}/sobre-mi/`,
  worksFor: { '@id': `${SITE.url}/#organization` },
  sameAs: SITE.author.sameAs,
};

// --- Schema de artículo (solo cuando type === 'article') ---
const articleSchema =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        url: pageUrl,
        inLanguage: SITE.language,
        author: { '@id': `${SITE.url}/#person` },
        publisher: { '@id': `${SITE.url}/#organization` },
        ...(publishedDate && { datePublished: publishedDate }),
        ...(modifiedDate && { dateModified: modifiedDate }),
      }
    : null;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {SITE.brand}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / social -->
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content={SITE.brand} />

    <!-- Tipografías -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: entidades legibles por máquinas -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}
    <slot name="head-schema" />
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="logo">{SITE.brand}</a>
      <nav aria-label="Principal">
        <a href="/blog/">Guías</a>
        <a href="/sobre-mi/">Sobre mí</a>
        <a href="/#contacto" class="nav-cta">Auditoría gratuita</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p class="footer-entity">{SITE.description}</p>
      <p class="footer-meta">
        © {new Date().getFullYear()} {SITE.brand} · {SITE.organization.addressLocality}, Chile ·
        <a href={`mailto:${SITE.organization.email}`}>{SITE.organization.email}</a>
      </p>
    </footer>

    <style is:global>
      :root {
        --paper: #f7f8f5;
        --ink: #12161b;
        --ink-soft: #4b5563;
        --cobalt: #2547f4;
        --cobalt-deep: #1a34c0;
        --cite-bg: #d9f2e3;
        --cite-ink: #0b6b45;
        --line: #dfe3da;
        --font-display: 'Archivo', system-ui, sans-serif;
        --font-body: 'Inter', system-ui, sans-serif;
        --font-mono: 'IBM Plex Mono', monospace;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { animation: none !important; transition: none !important; }
      }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.65;
      }
      h1, h2, h3 {
        font-family: var(--font-display);
        line-height: 1.12;
        letter-spacing: -0.015em;
        text-wrap: balance;
      }
      a { color: var(--cobalt); }
      a:focus-visible {
        outline: 3px solid var(--cobalt);
        outline-offset: 3px;
        border-radius: 2px;
      }
      main { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

      .site-header {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .logo {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 1.05rem;
        color: var(--ink);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .site-header nav { display: flex; gap: 1.5rem; align-items: center; }
      .site-header nav a {
        color: var(--ink);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
      }
      .site-header nav a:hover { color: var(--cobalt); }
      .nav-cta {
        background: var(--ink);
        color: var(--paper) !important;
        padding: 0.5rem 1rem;
        border-radius: 999px;
      }
      .nav-cta:hover { background: var(--cobalt); color: #fff !important; }

      .site-footer {
        max-width: 72rem;
        margin: 5rem auto 0;
        padding: 2.5rem 1.5rem 3rem;
        border-top: 1px solid var(--line);
        font-size: 0.9rem;
        color: var(--ink-soft);
      }
      .footer-entity { max-width: 46rem; }
    </style>
  </body>
</html>
